{
  "expo": {
    "name": "Kalima | كلمة",
    "slug": "kalima",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kalima",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kalima.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2C2A28",
        "foregroundImage": "./assets/images/android-adaptive-foreground.png",
        "monochromeImage": "./assets/images/android-adaptive-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.francisayyad.kalima"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#2C2A28",
          "defaultChannel": "daily-reminders"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-transparent.png",
          "imageWidth": 1,
          "backgroundColor": "#2C2A28",
          "dark": {
            "image": "./assets/images/splash-transparent.png",
            "backgroundColor": "#2C2A28"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bd31e6dc-a78a-4368-87a4-7e427166f647"
      }
    }
  }
}
